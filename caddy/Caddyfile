# Trusted HTTPS via Let's Encrypt DNS-01 (Vercel DNS).
# Works when DNS points to your Tailscale IP — no public port 443 required.
#
# Requires in .env:
#   ACME_EMAIL=you@example.com
#   VERCEL_API_TOKEN=...  (Vercel account token with DNS access)

{
	email {$ACME_EMAIL}
	acme_dns vercel {env.VERCEL_API_TOKEN}
}

(common) {
	encode gzip zstd
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options nosniff
	}
}

jellyfin.{$BASE_DOMAIN} {
	import common
	reverse_proxy jellyfin:8096
}

sonarr.{$BASE_DOMAIN} {
	import common
	reverse_proxy sonarr:8989
}

radarr.{$BASE_DOMAIN} {
	import common
	reverse_proxy radarr:7878
}

bazarr.{$BASE_DOMAIN} {
	import common
	reverse_proxy bazarr:6767
}

prowlarr.{$BASE_DOMAIN} {
	import common
	reverse_proxy prowlarr:9696
}

qbittorrent.{$BASE_DOMAIN} {
	import common
	reverse_proxy qbittorrent:8080
}
