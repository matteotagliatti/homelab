# Copy to .env and adjust for your host:
#   cp .env.example .env

# User/group for LinuxServer and similar containers (id -u / id -g)
PUID=1000
PGID=1000

# https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIMEZONE=Europe/Rome

# Absolute path to this git repo (Homer dashboard config lives in ./homer)
HOMELAB_DIR=/home/user/homelab

# Service runtime data — outside the repo, not tracked by git
CONFIG_DIR=/home/user/homelab-config

# Media, torrents, and book data
DATA_DIR=/home/user

# FlareSolverr (optional — defaults shown)
LOG_LEVEL=info
LOG_HTML=false
CAPTCHA_SOLVER=none

# Calibre-Web-Automated metadata (optional)
# https://docs.hardcover.app/api/getting-started/
HARDCOVER_TOKEN=

# Seerr (optional)
SEERR_LOG_LEVEL=info

# Caddy reverse proxy (HTTPS via Let's Encrypt + Vercel DNS)
BASE_DOMAIN=mtttgl.dev
HOMELAB_HOST=homelab.mtttgl.dev
ACME_EMAIL=you@example.com
# Vercel API token — https://vercel.com/account/settings/tokens
VERCEL_API_TOKEN=

# Caddy host ports → container 80/443. Defaults suit rootless Podman (ports >= 1024).
# 8880/8443 — 8080 is qBittorrent, 8081 Homer, 8083 CWA, 8084 Shelfmark.
# For clean URLs (https://homelab… without :8443), set sysctl per README then use 80/443:
# CADDY_HTTP_PORT=80
# CADDY_HTTPS_PORT=443
CADDY_HTTP_PORT=8880
CADDY_HTTPS_PORT=8443
